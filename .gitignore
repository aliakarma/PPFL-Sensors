# fl-privacy-project .gitignore

# ── Python ───────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
*.so

# ── Virtual environments ──────────────────────────────────────────
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ── Dataset (must be downloaded separately) ───────────────────────
data/raw/UCI HAR Dataset/
data/raw/*.zip
data/raw/*.tar.gz
# Keep the raw/ directory itself
!data/raw/.gitkeep

# ── Experiment outputs (large; not version-controlled) ───────────
results/logs/*/              # individual run directories
# Keep directory structure
!results/logs/.gitkeep
# ── PyTorch / model artefacts ────────────────────────────────────
*.pt
*.pth
*.ckpt
*.bin

# ── Jupyter ──────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── IDE / OS ─────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────
*.log
logs/

# ── Coverage ─────────────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
/data/__MACOSX
/data/UCI HAR Dataset
/data/raw
/data/UCI_HAR_Dataset/train
/data/UCI_HAR_Dataset/test
/data/UCI_HAR_Dataset

# --- Strict Publication Cleanliness ---
results/logs/
!results/plots/
!results/noise_sweep.csv
!results/final_report.md
temp_*.py
read_all*.py
*.jsonl
